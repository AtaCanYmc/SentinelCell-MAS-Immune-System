# Vector Database Provider (CHROMADB, IN_MEMORY, PINECONE, PGVECTOR)
VECTOR_DB_PROVIDER=IN_MEMORY

# Schema Registry Configuration
# Options: REDIS, SUPABASE, MONGO, FIREBASE, IN_MEMORY, FILE
SCHEMA_REGISTRY_PROVIDER=IN_MEMORY

# Supabase Settings (If SCHEMA_REGISTRY_PROVIDER=SUPABASE)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-api-key

# MongoDB Settings (If SCHEMA_REGISTRY_PROVIDER=MONGO)
MONGO_URI=mongodb://localhost:27017

# Firebase Settings (If SCHEMA_REGISTRY_PROVIDER=FIREBASE)
FIREBASE_CREDENTIALS_PATH=/path/to/serviceAccountKey.json

# PGVector Configuration
POSTGRES_URI=postgresql://sentinel:sentinelpass@localhost:5432/sentinel_db

# Pinecone Configuration
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=sentinel-healing-memory

# Fallback Priority Order (comma separated)
PROVIDER_ORDER=OPENAI,DEEPSEEK,GEMINI,GROQ,LOCAL_OLLAMA,ANTHROPIC

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# DeepSeek Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# Google Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Anthropic Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Groq Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# Local Ollama Configuration
OLLAMA_MODEL=llama3
