# ==========================================
# Core Infrastructure & Environment
# ==========================================
ENVIRONMENT=development
HOSTNAME=localhost
REDIS_URL=redis://localhost:6379/0

# Message Broker (REDIS, KAFKA, RABBITMQ)
MESSAGE_BROKER=REDIS
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
RABBITMQ_URL=amqp://guest:guest@localhost/

# ==========================================
# Security & Performance Limits
# ==========================================
API_KEY_SECRET=super_secret_api_key_123
LLM_RATE_LIMIT_PER_MIN=50
MAX_PAYLOAD_SIZE=10000
MAX_PAYLOAD_DEPTH=5
MAX_PAYLOAD_KEYS=50
PASSIVE_MONITORING=false

# ==========================================
# Resilience (Quarantine & Circuit Breaker)
# ==========================================
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN=60
QUARANTINE_ERROR_THRESHOLD=5
QUARANTINE_THRESHOLD=30
QUARANTINE_COOLDOWN_SECONDS=30
QUARANTINE_WINDOW_SECONDS=60
MAX_REPAIR_ATTEMPTS=3

# ==========================================
# Semantic & ML Guards
# ==========================================
SEMANTIC_DRIFT_THRESHOLD=0.85
HITL_ENABLED=false

# ==========================================
# LLM Providers (Fallback Priority Order)
# ==========================================
PROVIDER_ORDER=LOCAL_OLLAMA,OPENAI,DEEPSEEK,GEMINI,GROQ,ANTHROPIC

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# Local Ollama
OLLAMA_MODEL=llama3

# ==========================================
# Schema Registry & Validation
# ==========================================
# Options: REDIS, POSTGRES, SQLITE, SUPABASE, MONGO, FIREBASE, IN_MEMORY, FILE
SCHEMA_REGISTRY_PROVIDER=IN_MEMORY
SCHEMA_CACHE_TTL_SECONDS=300
MCP_FAILURE_POLICY=FAIL_CLOSED
SQLITE_DB_PATH=schemas.db
SCHEMA_POSTGRES_URI=postgresql://sentinel:sentinelpass@localhost:5432/sentinel_db
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-api-key
MONGO_URI=mongodb://localhost:27017
FIREBASE_CREDENTIALS_PATH=/path/to/serviceAccountKey.json

# ==========================================
# Vector Database / Memory (Semantic Cache)
# ==========================================
# Provider (CHROMADB, IN_MEMORY, PINECONE, PGVECTOR)
VECTOR_DB_PROVIDER=CHROMADB
POSTGRES_URI=postgresql://sentinel:sentinelpass@localhost:5432/sentinel_db
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=sentinel-healing-memory

# ==========================================
# Observability & Alerting
# ==========================================
TELEMETRY_LOG_LEVEL=INFO
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# Elasticsearch
ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_URL=http://elasticsearch-1:9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=supersecret_es_pass
ES_JAVA_OPTS="-Xms512m -Xmx512m"

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=supersecret_grafana_pass
